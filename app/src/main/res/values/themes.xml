<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AdasBountyRun" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_deep</item>
        <item name="colorSecondary">@color/brand_orange</item>
        <item name="colorSecondaryVariant">@color/brand_orange_deep</item>
        <item name="android:colorBackground">@color/brand_dark</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:navigationBarColor">@color/brand_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Splash uses the branded window background so the logo shows immediately -->
    <style name="Theme.AdasBountyRun.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_dark</item>
        <!-- Use the same icon as your launcher or a specific splash icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AdasBountyRun</item>
    </style>

</resources>
