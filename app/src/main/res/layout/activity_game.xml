<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <com.adas.bountyrun.engine.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Steering (bottom-left) -->
    <Button
        android:id="@+id/btnLeft"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="28dp"
        android:text="@string/btn_left"
        android:textSize="30sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_control" />

    <Button
        android:id="@+id/btnRight"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="128dp"
        android:layout_marginBottom="28dp"
        android:text="@string/btn_right"
        android:textSize="30sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_control" />

    <!-- Pedals (bottom-right) -->
    <Button
        android:id="@+id/btnBrake"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="144dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_brake"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_brake" />

    <Button
        android:id="@+id/btnGas"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_accel"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_gas" />

    <!-- Top-right utility buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="horizontal"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="16dp">

        <ToggleButton
            android:id="@+id/btnSensor"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:textOff="SENSORS"
            android:textOn="SENSORS"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="10dp" />

        <ToggleButton
            android:id="@+id/btnVoice"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:textOff="VOICE"
            android:textOn="VOICE"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="10dp" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="II"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

</FrameLayout>
