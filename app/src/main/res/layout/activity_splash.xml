<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Emblem (replace with @drawable/logo raster for exact artwork) -->
        <ImageView
            android:id="@+id/logoEmblem"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_logo_emblem"
            android:contentDescription="@string/app_name" />

        <!-- Wordmark: ADAS / BOUNTY / RUN -->
        <TextView
            android:id="@+id/wordAdas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADAS"
            android:textColor="@color/brand_steel"
            android:textSize="46sp"
            android:textStyle="bold"
            android:letterSpacing="0.18"
            android:shadowColor="#802E9BE6"
            android:shadowDx="0" android:shadowDy="0" android:shadowRadius="14"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:id="@+id/wordBounty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOUNTY "
                android:textColor="@color/brand_orange"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />
            <TextView
                android:id="@+id/wordRun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RUN"
                android:textColor="@color/brand_blue"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textColor="@color/brand_steel"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:alpha="0.85"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signature"
            android:textColor="@color/brand_orange"
            android:textSize="11sp"
            android:alpha="0.7"
            android:layout_marginTop="18dp" />

        <ProgressBar
            android:id="@+id/loadBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="220dp"
            android:layout_height="4dp"
            android:layout_marginTop="18dp"
            android:progressTint="@color/brand_blue"
            android:indeterminate="false"
            android:max="100" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:text="@string/disclaimer"
        android:textColor="@color/brand_steel"
        android:textSize="10sp"
        android:alpha="0.6"
        android:paddingHorizontal="16dp"
        android:gravity="center" />

</FrameLayout>
