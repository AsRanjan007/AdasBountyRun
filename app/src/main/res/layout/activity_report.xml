<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LEVEL REPORT"
            android:textColor="@color/brand_steel"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvGrade"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/white"
                android:textSize="52sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvGradeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excellent"
                    android:textColor="@color/brand_blue"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/brand_steel"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADAS Prevention Insights"
            android:textColor="@color/brand_orange"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvPrevention"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_steel"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnPrimary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="NEXT LEVEL"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/btn_primary" />

            <Button
                android:id="@+id/btnMenu"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:text="MENU"
                android:textColor="@color/white"
                android:background="@drawable/chip_bg" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/disclaimer"
            android:textColor="@color/brand_steel"
            android:textSize="11sp"
            android:alpha="0.6"
            android:gravity="center"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
